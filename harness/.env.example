# harness/.env.example — copy to .env and fill in values

NOTION_API_KEY=
NOTION_DATABASE_ID=          # the tickets database ID
NOTION_AGENT_USER_ID=        # Notion user ID for the agent account
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=              # xapp-... Socket Mode app-level token (from Slack app settings → Socket Mode)
SLACK_USER_TOKEN=            # still required by poll-notion reply lookups; no longer used for Slack polling
SLACK_CHANNEL_ID=            # single channel to watch
GITHUB_TOKEN=
GITHUB_REPO=                 # format: owner/repo

# Self-improvement loop
SLACK_ALERT_CHANNEL=         # channel ID for circuit breaker alerts (optional)
CLAUDE_PROJECTS_DIR=         # override ~/.claude/projects/ if non-standard (optional)
